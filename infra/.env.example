# ── App ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Ports (bound to 127.0.0.1 in Docker Compose) ───
# Exposed only via Caddy reverse proxy in production
WEB_PORT=4000
API_PORT=4001

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Postgres ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/castrater
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=castrater

# ── Scaffold Selections ─────────────────────────────
AUTH_PROVIDER=passkey
SESSION_PROVIDER=cookie
CUSTODY_PROVIDER=local

# ── Demo Auth ───────────────────────────────────────
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_DISPLAY_NAME=Demo User

# ── Local Custody ───────────────────────────────────
# Real local secp256k1 signing for development. Unsafe for production custody.
LOCAL_CUSTODY_SECRET=change-me-local-custody-secret

# ── Quilibrium SDK Custody ──────────────────────────
# Used only when CUSTODY_PROVIDER=quilibrium-sdk
QUILIBRIUM_QKMS_SERVER=https://qkms.quilibrium.com
QUILIBRIUM_QNZM_SERVER=https://qnzm.quilibrium.com
QUILIBRIUM_APP_ID=
QUILIBRIUM_APP_SECRET=

# ── Storage ─────────────────────────────────────────
STORAGE_BASE_DIR=./storage

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4000

# ── WebAuthn / Session ──────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=castrater-app-kit
WEBAUTHN_ORIGIN=http://localhost:4000
SESSION_COOKIE_NAME=castrater_session
SESSION_TTL_HOURS=168
AUTH_INSECURE_COOKIE=true
AUTH_CHALLENGE_TTL_SECONDS=300

# ── Demo App ────────────────────────────────────────
DEFAULT_APP_SLUG=default
DEFAULT_APP_NAME=Default Demo App

VITE_API_URL=http://localhost:4001
