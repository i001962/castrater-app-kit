# ── App ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Ports (bound to 127.0.0.1 in Docker Compose) ───
# Exposed only via Caddy reverse proxy in production
WEB_PORT=4000
API_PORT=4001

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Postgres (optional) ─────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/castrater
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=castrater

# ── qKMS (optional) ─────────────────────────────────
# Leave empty to use MockQkmsClient (dev only — UNSAFE for production)
QKMS_URL=
QKMS_API_KEY=

# ── HyperSnap ───────────────────────────────────────
HYPERSNAP_URL=https://hypersnap.castrater.xyz

# ── Inference (optional) ────────────────────────────
# INFERENCE_MODE: mock | local | remote
INFERENCE_MODE=mock
INFERENCE_BASE_URL=http://localhost:11434
INFERENCE_MODEL=llama3.2
INFERENCE_EMBEDDING_MODEL=nomic-embed-text
INFERENCE_TIMEOUT_MS=120000

# ── Storage ─────────────────────────────────────────
STORAGE_BASE_DIR=./storage

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4000

# ── Farcaster / Mini App ─────────────────────────────
# Set your app domain when deploying
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
VITE_API_URL=http://localhost:4001
